#!/bin/bash
# ~/.local/bin/set-wallpaper.sh

while read -r file; do
    [ -f "$file" ] || continue

    # 1. Generate colors and set wallpaper
    wal -i "$file" -n
    feh --bg-fill "$file"
    
    # 2. Update Xresources
    xrdb -merge ~/.cache/wal/colors.Xresources
    
    # 3. Update application-specific configs
    ~/.local/bin/i3-theme.sh
    cp ~/.cache/wal/colors-polybar ~/.config/polybar/colors-polybar
    cp ~/.cache/wal/dunstrc ~/.config/dunst/dunstrc

    # 4. Final Reload Cycle (Run once)
    i3-msg reload > /dev/null 2>&1
    polybar-msg cmd restart > /dev/null 2>&1
    
    # Restart Dunst
    pkill dunst
    dunst -config ~/.config/dunst/dunstrc &
    
    # Refresh Kitty
    kill -USR1 "$(pgrep -u "$USER" kitty)" 2>/dev/null
    
    # 5. Success Notification
    notify-send "Theme Applied" "Wallpaper: $(basename "$file")" -u normal
done
