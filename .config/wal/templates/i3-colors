# i3 color definitions generated by pywal
set $bg {background}
set $bg-alt {color8}
set $fg {foreground}
set $fg-alt {foreground}
set $primary {color1}
set $secondary {color2}
set $alert {color3}
set $disabled {color7}

# Window borders
client.focused          $primary $primary $fg $primary
client.unfocused        $bg $bg $fg $bg
client.urgent           $alert $alert $fg $alert
