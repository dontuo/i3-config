# --- Main Configuration ---
set $mod Mod4
# Point to the file generated by pywal
include /home/user/.cache/wal/i3-colors
# Include the Gentoo Dark Theme
#include themes/gentoo_dark
include autostart.conf 
include keybinds.conf 

font pango:Terminess Nerd Font 12

# rules
workspace 9 output HDMI-A-0
floating_modifier $mod
for_window [class="floating"] floating enabled move position center
for_window [class="com.github.th_ch.youtube_music"] floating enable move position center
gaps inner 5px
new_window 1pixel
default_border pixel 
focus_follows_mouse yes
mouse_warping output

# Include the generated color file
set_from_resource $bg color0
set_from_resource $fg color7
set_from_resource $border color4

# Apply to windows
client.focused $border $border $fg $border
client.unfocused $bg $bg $fg $bg
